  "NequIP": {
    "env": "nequip",
    "python": "${OH_MY_MLIP_HOME}/envs/nequip/bin/python",
    "default_version": "NequIP-OAM-XL",
    "model_source": "${OH_MY_MLIP_HOME}/models/compiled/{sm86,sm89}/ (compiled .pt2, recompiled/reselected on user GPU)",
    "note": "arch-pinned. Pick sm86/sm89 by host GPU. sm89 (L40S) verified single-point. NequIPCalculator ASE path is from_compiled_model ONLY (no uncompiled load) -> the per-arch .pt2 is required, not optional; it is reselected/recompiled on the user GPU, never baked into a distributed tarball.",
    "accel": {
      "tool": "openequivariance",
      "install": "pip install openequivariance",
      "compile_cmd": "nequip-compile <ckpt> <out>.nequip.pt2 --mode aotinductor --device cuda --target ase --modifiers enable_OpenEquivariance",
      "load_note": "import openequivariance; NequIPCalculator.from_compiled_model(<file>, device='cuda')  (use a torchscript .nequip.pth for torch<2.10; LAMMPS deploy: nequip-prepare-lmp-mliap)",
      "verify": "python -c 'import openequivariance'",
      "gpu_required": true,
      "verified": false,
      "provenance": "upstream-doc",
      "last_gpu_verified": null
    },
    "import": ["import openequivariance", "from nequip.ase import NequIPCalculator"],
