        "gated": false, "license_url": null, "weights": "auto-download", "weights_fetch": "by-name", "weights_source": "mh-1", "weights_source_url": "https://github.com/ACEsuit/mace-foundations/releases/tag/mace_mh_1", "validation": "validated_sm89", "note": "verify head name (OMAT uses head='omat_pbe'; confirm OC20 head with jumoon)",
