{
  "_meta": {
    "description": "oh-my-mlip public MLIP registry. A user's agent (or oh_my_mlip.provider) reads this to resolve an env, its interpreter, and the import/inference code for each model. Public edition of the internal catbench roster.",
    "readonly": true,
    "home_var": "OH_MY_MLIP_HOME",
    "conda_root": "${OH_MY_MLIP_HOME}/envs",
    "models_root": "${OH_MY_MLIP_HOME}/models",
    "interpreter_pattern": "${OH_MY_MLIP_HOME}/envs/<env>/bin/python",
    "shared_env_file": "${OH_MY_MLIP_HOME}/env.sh",
    "source_policy": "Each framework's env+model is unified to the fastest validated setup. Same checkpoint = same accuracy; only speed differs across contributors.",
    "field_guide": {
      "env": "conda env name; the relocatable env unpacks to ${OH_MY_MLIP_HOME}/envs/<env>",
      "default_version": "optional; for a multi-version framework, the version key resolve() selects when version=None. Must be one of the framework's version keys.",
      "python": "interpreter path of that framework's env, ${OH_MY_MLIP_HOME}-relative (do NOT use conda activate)",
      "import": "import lines for the top of a generated run script",
      "inference": "calculator construction code (intra-env)",
      "arch_pinned": "if true, pick the sm86/sm89 variant matching the host GPU (sm86=A5000/A6000, sm89=L40S); arch-specific .pt2 is reselected/recompiled on the user GPU, never baked into a distributed tarball",
      "note": "free-form caveats agents must respect",
      "status": "free-form provenance/validation provenance string carried verbatim from the internal registry",
      "env_run": "optional env-var prefix that MUST wrap the interpreter invocation (key=value allowlist only; e.g. LD_LIBRARY_PATH=\"\")",
      "gated": "bool. if true, weights require accepting an upstream license and using the user's own HF_TOKEN; gated weights are NEVER redistributed by this repo",
      "license_url": "string|null. URL of the upstream weights license to accept before download (set for gated models)",
      "weights": "how weights are obtained: 'bundled' (inside the conda-pack tarball) | 'auto-download' (fetched by name to a shared cache on first run) | 'on-demand-hf' (fetched from Hugging Face Hub, may be gated)",
      "weights_fetch": "fetch mechanism: 'by-name' (resolved by model name/cache) | 'url' (explicit download URL) | 'gated-hf' (gated HF repo requiring license acceptance + HF_TOKEN)",
      "weights_source": "the source value matching weights_fetch: an HF repo id (owner/name) for gated-hf, an http(s) URL (or the 'TODO-owner-review' placeholder, filled with the real official link by a later goal) for url, a resolver name/placeholder for by-name",
      "validation": "host-GPU validation state: 'validated_sm86' | 'validated_sm89' (single-point + D3 verified on that arch) | 'gpu_pending' (env/load OK but GPU single-point and/or D3 not yet verified) | 'cpu_only'"
    },
    "gpu_arch": {
      "sm86": {
        "gpu": [
          "A5000",
          "A6000"
        ]
      },
      "sm89": {
        "gpu": [
          "L40S"
        ]
      }
    },
    "catbench": "All envs ship catbench. D3: from catbench.dispersion import DispersionCorrection; calc = DispersionCorrection().apply(calc). The arch-specific pair_d3.so is NOT baked into distributed tarballs; it recompiles on the user GPU on first run (needs nvcc; see env.sh).",
    "shipped_v1": [
      "MACE",
      "SevenNet"
    ],
    "note": "v1 authors the MACE + SevenNet distribution pipeline; their tarballs are upload-pending the compute checkpoint (build+publish + foreign-host end-to-end not yet run). All other rows are carried at their TRUE validation state; rows marked validation='gpu_pending' are env/load-verified only and are Phase-2 packaging targets."
  },
  "SevenNet": {
    "env": "sevennet",
    "python": "${OH_MY_MLIP_HOME}/envs/sevennet/bin/python",
    "default_version": "SevenNet-MF-OMPA",
    "model_source": "bundled in package (sevenn/pretrained_potentials)",
    "accel": {
      "tool": "openequivariance",
      "install": "pip install sevenn[oeq]  (openequivariance; or sevenn[cueq12]/sevenn[cueq13] for cuEquivariance by CUDA major)",
      "compile_cmd": null,
      "load_note": "enable at calculator construction: SevenNetCalculator(..., enable_oeq=True)  (or --enable_oeq / --enable_cueq on the sevenn CLI)",
      "verify": "python -c 'from sevenn.nn.oeq_helper import is_oeq_available; print(is_oeq_available())'",
      "gpu_required": true,
      "verified": false,
      "provenance": "upstream-doc",
      "last_gpu_verified": null
    },
    "import": ["from sevenn.calculator import SevenNetCalculator"],
    "versions": {
      "SevenNet-MF-OMPA": {"mlip_name": "SevenNet-MF-OMPA", "training_set": ["OMat24", "sAlex", "MPtrj"],
        "gated": false, "license_url": null, "weights": "bundled", "weights_fetch": "by-name", "weights_source": "7net-mf-ompa", "weights_source_url": "https://sevennet.readthedocs.io/en/latest/user_guide/pretrained.html", "validation": "validated_sm89",
        "inference": ["calc = SevenNetCalculator('7net-mf-ompa', modal='mpa', enable_oeq=True)"]},
      "SevenNet-Omni": {"mlip_name": "SevenNet-Omni", "training_set": ["OMat24", "sAlex", "MPtrj"],
        "gated": false, "license_url": null, "weights": "bundled", "weights_fetch": "by-name", "weights_source": "7net-omni", "weights_source_url": "https://sevennet.readthedocs.io/en/latest/user_guide/pretrained.html", "validation": "validated_sm89",
        "inference": ["calc = SevenNetCalculator('7net-omni', modal='mpa', enable_oeq=True)"]}
    }
  },
