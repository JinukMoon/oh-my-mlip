# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- conda-pack tarballs / packaged envs (never commit multi-GB artifacts) ---
*.tar.gz
*.tar
*.tgz
envs/*/

# --- Model weights / checkpoints (gated weights must never be committed) ---
*.pt
*.pt2
*.pth
*.ckpt
*.model
*.so

# --- Caches ---
.cache/
*.log
.DS_Store

# --- HF tokens / secrets (never commit a token; keep it OUTSIDE the repo) ---
.hf_token
*.hf_token
*token*
# ...but these are real, token-free repo files that must stay tracked:
!docs/hf_token.md
!docs/gated_models.md
!scripts/verify_no_token.py
!tests/test_verify_no_token.py

# --- OMC orchestration state (never publish) ---
.omc/

# --- Downloaded weights, caches, runtime state (never publish) ---
# weights + HF caches are fetched on-demand; gated blobs must never be committed
models/
cache/
# background sweep results/logs (runtime state, not source)
.sweep/
# internal ultragoal closure evidence
.gjc_closure_artifacts/
env_map.local.json
